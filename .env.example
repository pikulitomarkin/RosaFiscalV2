# Configurações da Aplicação
APP_NAME="NFS-e Automation System"
APP_VERSION="1.0.0"
DEBUG=False
SECRET_KEY="your-secret-key-here-change-in-production"

# Banco de Dados PostgreSQL
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/nfse_db"
DB_ECHO=False

# API Nacional NFS-e (ADN - Ambiente de Disponibilização Nacional)
NFSE_API_BASE_URL="https://api.nfse.gov.br/adn"
NFSE_API_AMBIENTE="HOMOLOGACAO"  # HOMOLOGACAO ou PRODUCAO
NFSE_API_TIMEOUT=30
NFSE_API_MAX_RETRIES=3

# Certificado Digital A1
CERTIFICATE_PATH="certificados/cert.pem"
CERTIFICATE_PASSWORD="sua_senha_aqui"

# Configurações de Processamento
MAX_BATCH_SIZE=600
MIN_BATCH_SIZE=1
CONCURRENT_REQUESTS=10

# Configurações de Log
LOG_LEVEL="INFO"
LOG_FILE="logs/nfse_automation.log"

# Autenticação (Exemplo - Use hash bcrypt em produção)
# Use: from bcrypt import hashpw, gensalt; hashpw(b"senha", gensalt()).decode()
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="$2b$12$example_hash_here"

# IPM/Atende.Net - NFS-e Prefeitura Santa Rosa-RS (Nathalia Gabriela Serviços de Saúde Ltda)
IPM_WEBSERVICE_URL="https://santarosa.atende.net/?pg=rest&service=WNERestServiceNFSe"
IPM_USUARIO="56169351000185"
IPM_SENHA="sua_senha_aqui"
IPM_AMBIENTE_TESTE=False

# Streamlit
# Use STREAMLIT_SERVER_PORT for local testing or to run the dashboard on a different port (ex.: 8502)
STREAMLIT_SERVER_PORT=8502
STREAMLIT_SERVER_ADDRESS="localhost"
